{
  "name": "remotion-video",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "remotion studio remotion/index.jsx",
    "render:intro":   "node node_modules/@remotion/cli/remotion-cli.js render remotion/index.jsx PortfolioIntro   out/portfolio-intro.mp4",
    "render:lora":    "node node_modules/@remotion/cli/remotion-cli.js render remotion/index.jsx LorawanShowcase  out/lorawan-showcase.mp4",
    "render:android": "node node_modules/@remotion/cli/remotion-cli.js render remotion/index.jsx AndroidShowcase  out/android-showcase.mp4",
    "render:cyber03": "node node_modules/@remotion/cli/remotion-cli.js render remotion/index.jsx Cyber03Showcase  out/cyber03-showcase.mp4",
    "render:cyber":   "node node_modules/@remotion/cli/remotion-cli.js render remotion/index.jsx CyberShowcase    out/cyber-showcase.mp4",
    "render:all":     "npm run render:intro && npm run render:lora && npm run render:android && npm run render:cyber03 && npm run render:cyber"
  },
  "dependencies": {
    "@remotion/cli": "4.0.435",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "remotion": "4.0.435"
  }
}
